{
  "name": "keyhint-for-mac",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Mac shortcut memory layer with a meaning-first HUD.",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build": "npm run build:web",
    "build:web": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check": "npm run check:web && npm run check:tauri-manifest",
    "check:web": "tsc --noEmit",
    "check:tauri-manifest": "cargo metadata --manifest-path src-tauri/Cargo.toml --no-deps --format-version 1 >/dev/null",
    "test": "npm run check && npm run test:mock-hud",
    "test:mock-hud": "node --experimental-strip-types scripts/verify-mock-hud.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16"
  }
}
